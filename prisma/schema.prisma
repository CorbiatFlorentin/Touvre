generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EventType {
  MICHOUI
  VIDE_GRENIER
}

enum TarifType {
  ADULTE
  ENFANT_MOINS_12
  ENFANT_MOINS_3
}

model Inscription {
  id              Int      @id @default(autoincrement())
  formulaireId    Int?     @map("formulaire_id")
  nom             String
  prenom          String?
  email           String
  phoneNumber     String?  @map("phone_number")
  event           EventType
  tarif           TarifType?
  accompteVerser  Boolean  @default(false) @map("accompte_verser")
  accompteMontant Int?
  createdAt       DateTime @default(now())

  @@index([event])
  @@index([formulaireId])
  @@map("inscription")
}

model Admin {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  createdAt     DateTime @default(now()) @map("created_at")
  lastLoginAt   DateTime? @map("last_login_at")

  @@map("admin")
}

model Newsletter {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  publishedAt DateTime @map("published_at")
  imagesJson  String   @map("images_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("newsletter")
}

model AssociationContent {
  id          Int      @id
  body        String
  updatedAt   DateTime @default(now()) @map("updated_at")
  members     AssociationMember[]

  @@map("association_content")
}

model AssociationMember {
  id            Int                @id @default(autoincrement())
  associationId Int                @map("association_id")
  name          String
  imageDataUrl  String             @map("image_data_url")
  sortOrder     Int                @default(0) @map("sort_order")
  association   AssociationContent @relation(fields: [associationId], references: [id], onDelete: Cascade)

  @@index([associationId, sortOrder])
  @@map("association_member")
}
