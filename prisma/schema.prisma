generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EventType {
  MICHOUI
  VIDE_GRENIER
}

enum TarifType {
  ADULTE
  ENFANT_MOINS_12
  ENFANT_MOINS_3
}

model Inscription {
  id              Int      @id @default(autoincrement())
  formulaireId    Int?     @map("formulaire_id")
  nom             String
  prenom          String?
  email           String
  phoneNumber     String?  @map("phone_number")
  event           EventType
  tarif           TarifType?
  accompteVerser  Boolean  @default(false) @map("accompte_verser")
  accompteMontant Int?
  createdAt       DateTime @default(now())

  @@index([event])
  @@index([formulaireId])
  @@map("inscription")
}

model Admin {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  createdAt     DateTime @default(now()) @map("created_at")
  lastLoginAt   DateTime? @map("last_login_at")

  @@map("admin")
}
